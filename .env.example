# ===========================================================================
# scraperX — Environment Configuration (TEMPLATE)
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values:
#
#     cp .env.example .env
#
# `.env` is gitignored and must NEVER be committed (it holds proxy creds).
# Every value below has a sane built-in default, so an empty .env still works.
# Booleans accept: true/false, 1/0, yes/no (case-insensitive).
# ===========================================================================

# ------------------------------------------------------------------
# Target
# ------------------------------------------------------------------
# Default start URL used when none is passed on the CLI / entered in the GUI.
TARGET_URL=

# ------------------------------------------------------------------
# Browser
# ------------------------------------------------------------------
# Run Chromium headless (true) or with a visible window (false).
# Headful is useful for debugging CAPTCHAs / bot-walls.
HEADLESS=true

# Optional: path to a specific Chromium binary. Leave empty to use the browser
# installed by `playwright install chromium`. Set this to point at a system
# Chromium or a browser bundled next to a compiled binary.
CHROMIUM_EXECUTABLE_PATH=

# ------------------------------------------------------------------
# Proxy — single proxy
# ------------------------------------------------------------------
# Full proxy URL, e.g. http://host:port or socks5://host:port
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ------------------------------------------------------------------
# Proxy — rotation pool
# ------------------------------------------------------------------
# Comma- or newline-separated list of proxy URLs to rotate through.
# Each entry may embed credentials: http://user:pass@host:port
# When set, this takes precedence over the single PROXY_URL above.
PROXY_LIST=

# ------------------------------------------------------------------
# Fingerprint / User-Agent spoofing
# ------------------------------------------------------------------
# Optional comma- or newline-separated pool of User-Agent strings to rotate.
# Leave empty to use the built-in modern desktop UA list.
USER_AGENTS=

# ------------------------------------------------------------------
# Resilience — retries, backoff & jitter
# ------------------------------------------------------------------
# Retries apply to timeouts, HTTP 429, and 5xx responses.
MAX_RETRIES=4
# Exponential backoff base in seconds: delay = BACKOFF_BASE ** attempt
BACKOFF_BASE=2
# Cap on any single backoff delay (seconds)
BACKOFF_MAX=60
# Add random jitter to backoff delays to avoid thundering-herd patterns
JITTER=true

# ------------------------------------------------------------------
# Timeouts (milliseconds)
# ------------------------------------------------------------------
REQUEST_TIMEOUT_MS=30000
NAV_TIMEOUT_MS=45000

# ------------------------------------------------------------------
# Crawl behaviour
# ------------------------------------------------------------------
# Number of pages fetched in parallel.
CONCURRENCY=1
# How many link-hops deep to crawl (0 = only the start page).
CRAWL_DEPTH=1
# Minimum delay between requests to the same host (politeness / rate limiting).
RATE_LIMIT_MS=1000

# ------------------------------------------------------------------
# Output & logging
# ------------------------------------------------------------------
OUTPUT_PATH=output/results.csv
# When true (default), write one CSV per website, named after its domain
# (e.g. output/example.com.csv), into the directory of OUTPUT_PATH. When false,
# write everything into the single OUTPUT_PATH file.
GROUP_BY_SITE=true
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
